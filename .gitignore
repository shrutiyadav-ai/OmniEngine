# =============================================================================
# OmniEngine — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment ---
.env
.env.local
.env.production
!.env.example

# --- Testing ---
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
coverage.xml
*.cover

# --- Node / Frontend ---
node_modules/
.next/
out/
.turbo/

# --- Docker ---
*.log

# --- Alembic ---
backend/alembic/versions/*.pyc

# --- Misc ---
*.bak
*.tmp
*.temp
.terraform/
*.tfstate
*.tfstate.backup
