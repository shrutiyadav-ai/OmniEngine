# =============================================================================
# OmniEngine — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
APP_NAME=OmniEngine
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=DEBUG

# API Security
API_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
# Comma-separated list of valid API keys for authentication
API_KEYS=dev-key-change-me-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Service Ports (Docker Compose)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=omniengine
POSTGRES_USER=omni
POSTGRES_PASSWORD=omni_dev_password
# Constructed automatically in docker-compose; override for external DB:
# DATABASE_URL=postgresql+asyncpg://omni:password@localhost:5432/omniengine

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Constructed automatically in docker-compose; override for external Redis:
# REDIS_URL=redis://localhost:6379/0

# Session TTL in seconds (default: 24 hours)
REDIS_SESSION_TTL=86400
# Rate limit: requests per minute per API key
RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
# Constructed automatically in docker-compose; override for external Qdrant:
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=omni_memories
QDRANT_EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# -----------------------------------------------------------------------------
# Model Router Configuration
# -----------------------------------------------------------------------------
# Default models per tier
MODEL_TIER_SMALL=gpt-4o-mini
MODEL_TIER_MEDIUM=gpt-4o
MODEL_TIER_LARGE=claude-sonnet-4-20250514
MODEL_TIER_REASONING=o1

# Vision-capable models (comma-separated)
VISION_MODELS=gpt-4o,gemini-1.5-pro,claude-sonnet-4-20250514

# Fallback chain (comma-separated, tried in order)
MODEL_FALLBACK_CHAIN=gpt-4o,claude-sonnet-4-20250514,gemini-1.5-pro

# Token thresholds for tier routing
TIER_SMALL_MAX_TOKENS=500
TIER_MEDIUM_MAX_TOKENS=2000

# Maximum recursion depth for agent loops
AGENT_RECURSION_LIMIT=25

# -----------------------------------------------------------------------------
# Cost Controls
# -----------------------------------------------------------------------------
# Maximum cost in USD per session before forced termination
SESSION_COST_CAP_USD=5.00
# Maximum cost in USD per single request
REQUEST_COST_CAP_USD=1.00
# Alert threshold (percentage of session cap)
COST_ALERT_THRESHOLD=0.80

# -----------------------------------------------------------------------------
# Tool Configuration
# -----------------------------------------------------------------------------

# Tavily Web Search
TAVILY_API_KEY=tvly-your-tavily-api-key-here
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced

# Code Interpreter Sandbox
SANDBOX_IMAGE=omniengine/sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY=256m
SANDBOX_MAX_CPU=0.5
SANDBOX_NETWORK_DISABLED=true

# Vision
VISION_DEFAULT_MODEL=gpt-4o
VISION_MAX_IMAGE_SIZE_MB=20

# Calendar (OAuth2 — future extension)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Memory & Context
# -----------------------------------------------------------------------------
# Context window threshold to trigger summarization (0.0 - 1.0)
CONTEXT_SUMMARIZATION_THRESHOLD=0.70
# Number of recent messages to always keep raw
MEMORY_ROLLING_BUFFER_SIZE=20
# Top-K results for semantic memory retrieval
MEMORY_TOP_K=5
# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Safety & Guardrails
# -----------------------------------------------------------------------------
# Confidence threshold below which disclaimer is added
SAFETY_CONFIDENCE_THRESHOLD=0.60
# Maximum consecutive tool failures before re-planning
MAX_TOOL_FAILURES=3
# Enable PII redaction in telemetry logs
PII_REDACTION_ENABLED=true

# -----------------------------------------------------------------------------
# Telemetry
# -----------------------------------------------------------------------------
# Enable/disable telemetry persistence
TELEMETRY_ENABLED=true
# Batch size for async telemetry writes
TELEMETRY_BATCH_SIZE=50

# -----------------------------------------------------------------------------
# Cleanup Cron
# -----------------------------------------------------------------------------
# Interval in seconds for state cleanup job (default: 1 hour)
CLEANUP_INTERVAL_SECONDS=3600
# Max age in seconds for inactive Redis sessions (default: 24 hours)
CLEANUP_MAX_SESSION_AGE=86400
# Max age in seconds for sandbox volumes (default: 24 hours)
CLEANUP_MAX_SANDBOX_AGE=86400
